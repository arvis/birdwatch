{
  "name": "mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest"
  },
  "jest": {
    "preset": "jest-expo",
    "globals": {
      "__DEV__": true
    },
    "moduleNameMapper": {
      "^expo/src/winter$": "<rootDir>/__mocks__/expo-winter.js",
      "^expo/src/winter/runtime\\.native$": "<rootDir>/__mocks__/expo-winter.js",
      "ImportMetaRegistry": "<rootDir>/__mocks__/ImportMetaRegistry.js"
    }
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~55.0.5",
    "expo-application": "~55.0.10",
    "expo-device": "~55.0.10",
    "expo-image-picker": "~55.0.11",
    "expo-router": "~55.0.4",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-get-random-values": "^2.0.0",
    "react-native-web": "^0.21.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.2.2",
    "@types/uuid": "^10.0.0",
    "jest": "^30.3.0",
    "jest-expo": "^55.0.9",
    "react-test-renderer": "^19.2.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
